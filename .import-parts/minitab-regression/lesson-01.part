<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="color-scheme" content="light dark">
  <meta name="theme-color" content="#ffffff">
  <title>Finding the Best Predictive Regression Model in Minitab | UpSkill Sprint</title>
  <meta name="description" content="A step-by-step, cross-validated workflow for selecting an interpretable linear, polynomial, interaction, or MARS regression model in Minitab.">
  <link rel="canonical" href="https://upskillsprint.com/lessons/minitab-best-predictive-regression-model.html">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Source+Serif+4:opsz,wght@8..60,500;8..60,600;8..60,700&family=Work+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/style.css">
  <script src="/theme.js"></script>
  <script src="/site-sections.js"></script>
  <style>
    :root {
      --lesson-max: 1160px;
      --lesson-reading: 820px;
      --success: #15803d;
      --success-soft: #ecfdf3;
      --danger: #b42318;
      --danger-soft: #fff1f0;
      --purple: #6941c6;
      --purple-soft: #f4f3ff;
      --blue: #175cd3;
      --blue-soft: #eff8ff;
      --shadow-soft: 0 14px 40px rgba(16, 24, 40, .08);
    }

    html { scroll-behavior: smooth; }
    body { margin: 0; }
    button, input, select { font: inherit; }
    .lesson-wrapper { background: var(--paper, #fff); color: var(--ink, #101828); }
    .lesson-wrapper * { box-sizing: border-box; }
    .lesson-wrapper .page { max-width: var(--lesson-max); margin: 0 auto; padding: 0 24px; }
    .lesson-wrapper p, .lesson-wrapper li { line-height: 1.72; }
    .lesson-wrapper h1, .lesson-wrapper h2, .lesson-wrapper h3, .lesson-wrapper h4 {
      font-family: "Source Serif 4", Georgia, serif;
      color: var(--ink, #101828);
    }
    .lesson-wrapper h2 { font-size: clamp(28px, 3vw, 38px); line-height: 1.15; margin: 0 0 18px; }
    .lesson-wrapper h3 { font-size: 23px; margin: 0 0 12px; }
    .lesson-wrapper a { color: var(--teal-dark, #0e7490); }
    .lesson-wrapper code, .equation, .menu-path {
      font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    }

    .reading-progress {
      position: fixed; inset: 0 auto auto 0; z-index: 1200; height: 4px; width: 0;
      background: var(--teal, #0e7490); transition: width .08s linear;
    }

    .lesson-hero {
      position: relative; overflow: hidden; padding: 86px 0 58px;
      border-bottom: 1px solid var(--line, #e4e7ec);
      background:
        radial-gradient(circle at 84% 18%, rgba(14,116,144,.12), transparent 28%),
        radial-gradient(circle at 8% 80%, rgba(240,195,106,.15), transparent 30%);
    }
    .hero-grid { display: grid; grid-template-columns: minmax(0, 1.12fr) minmax(340px, .88fr); gap: 54px; align-items: center; }
    .lesson-kicker { margin: 0 0 14px; color: var(--teal-dark, #0e7490); font-size: 12px; font-weight: 800; letter-spacing: .1em; text-transform: uppercase; }
    .lesson-hero h1 { max-width: 760px; margin: 0 0 20px; font-size: clamp(39px, 5vw, 62px); line-height: 1.02; }
    .hero-copy { max-width: 720px; margin: 0 0 24px; color: var(--ink-soft, #344054); font-size: 18px; line-height: 1.68; }
    .meta-row { display: flex; flex-wrap: wrap; gap: 9px; }
    .meta-pill { display: inline-flex; align-items: center; gap: 7px; padding: 8px 11px; border: 1px solid var(--line, #e4e7ec); border-radius: 999px; background: var(--card, #fff); color: var(--ink-soft, #344054); font-size: 12px; font-weight: 700; }
    .hero-panel { position: relative; min-height: 430px; border: 1px solid var(--line, #e4e7ec); border-radius: 18px; background: var(--card, #fff); box-shadow: var(--shadow-soft); padding: 26px; }
    .hero-panel-title { margin: 0 0 18px; font: 700 13px/1.3 "Work Sans", Arial, sans-serif; color: var(--ink-soft, #344054); text-transform: uppercase; letter-spacing: .07em; }
    .pathway { display: grid; gap: 12px; }
    .path-step { position: relative; display: grid; grid-template-columns: 42px 1fr; gap: 13px; align-items: center; padding: 14px; border: 1px solid var(--line, #e4e7ec); border-radius: 11px; background: var(--paper, #fff); }
    .path-step:not(:last-child)::after { content: ""; position: absolute; left: 34px; bottom: -13px; width: 2px; height: 13px; background: var(--teal, #0e7490); }
    .path-number { display: grid; place-items: center; width: 38px; height: 38px; border-radius: 10px; background: var(--tint, #f8fafc); color: var(--teal-dark, #0e7490); font-weight: 800; }
    .path-step strong { display: block; margin-bottom: 3px; font-size: 14px; }
    .path-step span { color: var(--muted, #667085); font-size: 12.5px; line-height: 1.45; }
    .path-pulse { position: absolute; left: 30px; top: 49px; width: 10px; height: 10px; border-radius: 50%; background: var(--amber, #f0c36a); box-shadow: 0 0 0 0 rgba(240,195,106,.45); animation: pulse 2.4s infinite; }
    @keyframes pulse { 70% { box-shadow: 0 0 0 12px rgba(240,195,106,0); } 100% { box-shadow: 0 0 0 0 rgba(240,195,106,0); } }

    .lesson-layout { display: grid; grid-template-columns: 250px minmax(0, 1fr); gap: 48px; align-items: start; padding: 44px 0 96px; }
    .lesson-nav { position: sticky; top: 92px; max-height: calc(100vh - 115px); overflow: auto; padding: 18px; border: 1px solid var(--line, #e4e7ec); border-radius: 12px; background: var(--card, #fff); }
    .lesson-nav-title { margin: 0 0 12px; font-size: 12px; color: var(--muted, #667085); font-weight: 800; letter-spacing: .07em; text-transform: uppercase; }
    .lesson-nav a { display: block; padding: 8px 9px; border-left: 2px solid transparent; color: var(--ink-soft, #344054); font-size: 13px; line-height: 1.35; text-decoration: none; }
    .lesson-nav a:hover, .lesson-nav a.active { border-left-color: var(--teal, #0e7490); background: var(--tint, #f8fafc); color: var(--ink, #101828); }

    .lesson-content { min-width: 0; }
    .lesson-section { scroll-margin-top: 96px; padding: 0 0 68px; }
    .section-intro { max-width: 780px; color: var(--ink-soft, #344054); font-size: 16px; }
    .learning-grid, .track-grid, .diagnostic-grid, .metric-grid { display: grid; gap: 16px; }
    .learning-grid { grid-template-columns: repeat(3, 1fr); margin-top: 26px; }
    .track-grid { grid-template-columns: repeat(2, 1fr); }
    .diagnostic-grid { grid-template-columns: repeat(2, 1fr); }
    .metric-grid { grid-template-columns: repeat(3, 1fr); }
    .lesson-card { border: 1px solid var(--line, #e4e7ec); border-radius: 12px; background: var(--card, #fff); padding: 22px; }
    .lesson-card h3, .lesson-card h4 { margin-top: 0; }
    .lesson-card p:last-child { margin-bottom: 0; }
    .card-number { display: grid; place-items: center; width: 34px; height: 34px; margin-bottom: 14px; border-radius: 9px; background: var(--tint, #f8fafc); color: var(--teal-dark, #0e7490); font-size: 13px; font-weight: 800; }

    .callout { margin: 24px 0; padding: 20px 22px; border-left: 4px solid var(--teal, #0e7490); border-radius: 0 10px 10px 0; background: var(--info-bg, #eff8ff); color: var(--ink-soft, #344054); }
    .callout strong { color: var(--ink, #101828); }
    .callout-warning { border-left-color: var(--amber, #f0c36a); background: var(--warning-bg, #fffaeb); }
    .callout-danger { border-left-color: var(--danger); background: var(--danger-bg, #fff1f0); }
    .callout-success { border-left-color: var(--success); background: var(--practice-bg, #ecfdf3); }
    .callout-purple { border-left-color: var(--purple); background: var(--purple-soft); }

    .equation-box { margin: 18px 0; padding: 19px; overflow-x: auto; border: 1px solid var(--line, #e4e7ec); border-radius: 10px; background: var(--tint, #f8fafc); text-align: center; }
    .equation { font-size: 16px; white-space: nowrap; }
    .term-chips { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 14px; }
    .term-chip { padding: 7px 10px; border: 1px solid var(--line, #e4e7ec); border-radius: 999px; background: var(--card, #fff); font-family: ui-monospace, monospace; font-size: 12px; }

    .interactive { margin: 28px 0; border: 1px solid var(--line, #e4e7ec); border-radius: 14px; background: linear-gradient(135deg, var(--card, #fff), var(--tint, #f8fafc)); overflow: hidden; }
    .interactive-head { display: flex; justify-content: space-between; gap: 18px; align-items: flex-start; padding: 21px 22px 17px; border-bottom: 1px solid var(--line, #e4e7ec); }
    .interactive-head h3 { margin: 0 0 5px; font-size: 21px; }
    .interactive-head p { margin: 0; color: var(--muted, #667085); font-size: 13.5px; }
    .interactive-badge { flex: 0 0 auto; padding: 7px 9px; border-radius: 999px; background: var(--teal, #0e7490); color: #fff; font-size: 11px; font-weight: 800; letter-spacing: .05em; text-transform: uppercase; }
    .interactive-body { padding: 22px; }
    .control-grid { display: grid; grid-template-columns: repe